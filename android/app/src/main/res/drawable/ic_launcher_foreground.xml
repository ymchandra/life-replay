<?xml version="1.0" encoding="utf-8"?>
<!--
  Life Replay icon foreground — redesigned.
  Design: three timeline dots connected by a horizontal bar, a short
  vertical connector, and a right-pointing play triangle.
  All elements are centred and kept within the safe zone (x 18–90, y 18–90).
  White on transparent — the background drawable shows through.
  Viewport 108×108 dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Horizontal timeline bar (y centre=37, height=4, x 34→74) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,35 L74,35 L74,39 L34,39 Z"/>

    <!-- Left dot — circle centred at (34,37) r=6 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,31 A6,6 0 1 0 34,43 A6,6 0 1 0 34,31 Z"/>

    <!-- Centre dot — circle centred at (54,37) r=6 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,31 A6,6 0 1 0 54,43 A6,6 0 1 0 54,31 Z"/>

    <!-- Right dot — circle centred at (74,37) r=6 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M74,31 A6,6 0 1 0 74,43 A6,6 0 1 0 74,31 Z"/>

    <!-- Vertical connector from centre dot (y=43) to play triangle (y=61), width=4 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52,43 L56,43 L56,61 L52,61 Z"/>

    <!-- Play triangle — right-pointing, centred at (54,72)
         Vertices: left-top (40,62) · left-bottom (40,82) · right tip (68,72) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M40,62 L40,82 L68,72 Z"/>

</vector>

