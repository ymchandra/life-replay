<?xml version="1.0" encoding="utf-8"?>
<!--
  Life Replay icon foreground.
  Design: three timeline dots connected by a horizontal bar (life moments),
  with a right-pointing play triangle below (replay).
  White on transparent — amber background drawable shows through.
  Viewport 108×108 dp; Android safe zone is the inner 72×72 dp (x 18–90, y 18–90).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Horizontal timeline bar (y centre=42, height=4, x 24→84) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24,40 L84,40 L84,44 L24,44 Z"/>

    <!-- Left dot — circle centred at (24,42) r=7 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M24,35 a7,7 0 1,0 0.001,0 Z"/>

    <!-- Centre dot — circle centred at (54,42) r=7 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,35 a7,7 0 1,0 0.001,0 Z"/>

    <!-- Right dot — circle centred at (84,42) r=7 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M84,35 a7,7 0 1,0 0.001,0 Z"/>

    <!-- Play triangle — right-pointing, centre ≈ (54,68)
         Vertices: left-top (38,56) · left-bottom (38,80) · right (72,68) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,56 L38,80 L72,68 Z"/>

</vector>

